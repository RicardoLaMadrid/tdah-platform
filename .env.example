# ============================================================
# COPIA ESTE ARCHIVO como .env y completa los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# --- Flask ---
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=cambiar-esto-en-produccion

# --- Base de datos ---
DATABASE_URL=mysql+pymysql://root@localhost/tdah_platform

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-api03-tu-key-aqui
AI_MODEL=claude-haiku-4-5
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.3

# --- Algoritmo TDAH ---
TDAH_MIN_CONFIDENCE=50
TDAH_MIN_TESTS=2
TDAH_REEVAL_DAYS=30

# --- Google OAuth (opcional) ---
# Obtén estos valores en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-secret

# --- Twilio / WhatsApp (opcional) ---
# Empieza con sandbox: https://www.twilio.com/console/sms/whatsapp/sandbox
WHATSAPP_ENABLED=False
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Otros ---
JWT_SECRET_KEY=cambiar-esto-en-produccion
WHISPER_MODEL=base
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=52428800
